{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Jump to oldest Claude Code notification (ctrl+opt+n)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "n",
                                    "modifiers": { "mandatory": ["control", "option"] }
                                },
                                "to": [{ "shell_command": "/bin/zsh -l -c '$HOME/.local/bin/paend && /usr/bin/open -a Alacritty'" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "iso" }
        }
    ]
}